    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "node-cron": "^4.2.1",
    "prettier": "^3.8.3",
