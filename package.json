{
  "name": "surfsapp",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "tsc-files": "^1.1.4",
    "typescript": "~5.9.3"
  },
  "lint-staged": {
    "ui/**/*.{ts,tsx}": [
      "bash -c 'cd ui && eslint --fix --max-warnings 0 --no-warn-ignored \"$@\"' --",
      "prettier --write",
      "bash -c 'cd ui && tsc-files --noEmit \"$@\"' --"
    ],
    "ui/**/*.vue": [
      "bash -c 'cd ui && eslint --fix --max-warnings 0 --no-warn-ignored \"$@\"' --",
      "prettier --write",
      "bash -c 'cd ui && yarn --silent typecheck'"
    ],
    "backend/**/*.ts": [
      "bash -c 'cd backend && eslint --fix --max-warnings 0 --no-warn-ignored \"$@\"' --",
      "prettier --write",
      "bash -c 'cd backend && tsc-files --noEmit \"$@\"' --"
    ],
    "*.{js,json,md}": [
      "prettier --write"
    ]
  }
}
